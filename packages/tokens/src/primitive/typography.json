{
  "font": {
    "family": {
      "sans":    { "$value": "'Plus Jakarta Sans', 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif", "$type": "fontFamily" },
      "display": { "$value": "'Cabinet Grotesk', 'Plus Jakarta Sans', sans-serif", "$type": "fontFamily" },
      "mono":    { "$value": "'JetBrains Mono', 'Fira Code', monospace", "$type": "fontFamily" }
    },
    "weight": {
      "regular":   { "$value": "400", "$type": "fontWeight" },
      "medium":    { "$value": "500", "$type": "fontWeight" },
      "semibold":  { "$value": "600", "$type": "fontWeight" },
      "bold":      { "$value": "700", "$type": "fontWeight" },
      "extrabold": { "$value": "800", "$type": "fontWeight" }
    },
    "size": {
      "xs":   { "$value": "0.75rem",   "$type": "dimension" },
      "sm":   { "$value": "0.875rem",  "$type": "dimension" },
      "md":   { "$value": "1rem",      "$type": "dimension" },
      "lg":   { "$value": "1.125rem",  "$type": "dimension" },
      "xl":   { "$value": "1.25rem",   "$type": "dimension" },
      "2xl":  { "$value": "1.5rem",    "$type": "dimension" },
      "3xl":  { "$value": "2rem",      "$type": "dimension" },
      "4xl":  { "$value": "2.5rem",    "$type": "dimension" },
      "5xl":  { "$value": "3.25rem",   "$type": "dimension" }
    },
    "lineHeight": {
      "tight":    { "$value": "1.2",   "$type": "number" },
      "snug":     { "$value": "1.35",  "$type": "number" },
      "normal":   { "$value": "1.5",   "$type": "number" },
      "relaxed":  { "$value": "1.65",  "$type": "number" }
    },
    "letterSpacing": {
      "tighter": { "$value": "-0.04em", "$type": "dimension" },
      "tight":   { "$value": "-0.02em", "$type": "dimension" },
      "normal":  { "$value": "0em",     "$type": "dimension" },
      "wide":    { "$value": "0.02em",  "$type": "dimension" },
      "wider":   { "$value": "0.06em",  "$type": "dimension" }
    }
  }
}

{
  "shadow": {
    "xs":    { "$value": "0 1px 2px rgba(0, 0, 0, 0.04)",                                                                          "$type": "shadow" },
    "sm":    { "$value": "0 2px 4px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.06)",                                           "$type": "shadow" },
    "md":    { "$value": "0 4px 8px -2px rgba(0, 0, 0, 0.06), 0 2px 4px -2px rgba(0, 0, 0, 0.08)",                                 "$type": "shadow" },
    "lg":    { "$value": "0 12px 24px -4px rgba(0, 0, 0, 0.08), 0 4px 8px -4px rgba(0, 0, 0, 0.06)",                               "$type": "shadow" },
    "xl":    { "$value": "0 20px 40px -8px rgba(0, 0, 0, 0.1), 0 8px 16px -8px rgba(0, 0, 0, 0.08)",                               "$type": "shadow" },
    "2xl":   { "$value": "0 32px 64px -12px rgba(0, 0, 0, 0.14), 0 12px 24px -8px rgba(0, 0, 0, 0.1)",                             "$type": "shadow" },
    "glow":  { "$value": "0 0 20px rgba(255, 56, 92, 0.25), 0 0 40px rgba(255, 56, 92, 0.1)",                                      "$type": "shadow" },
    "inner": { "$value": "inset 0 2px 4px rgba(0, 0, 0, 0.06)",                                                                     "$type": "shadow" },
    "none":  { "$value": "none",                                                                                                      "$type": "shadow" }
  }
}
